{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartScan",
  "version": "1.0.0",
  "identifier": "com.smartscan.diagnostics",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SmartScan",
        "width": 1100,
        "height": 800,
        "center": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/Square150x150Logo.png",
      "icons/StoreLogo.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
