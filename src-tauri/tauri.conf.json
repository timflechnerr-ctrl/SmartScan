{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartScan",
  "version": "1.0.1",
  "identifier": "com.smartscan.diagnostics",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SmartScan",
        "width": 1100,
        "height": 800,
        "center": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNjFBMjk0OTBDM0EwNjcKUldSbm9NT1FsS0poSTJIZHA5ZVg2b2hsZmRsaFVkYlJxTDFxanVESG9wU2wwZFo4NXdra0c5MzEK",
      "endpoints": [
        "https://github.com/timflechnerr-ctrl/SmartScan/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/Square150x150Logo.png",
      "icons/StoreLogo.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
